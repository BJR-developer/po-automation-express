# ─────────────────────────────────────────────
# Shopify App Credentials (from Partner Dashboard)
# ─────────────────────────────────────────────
SHOPIFY_CLIENT_ID=your_client_id_here
SHOPIFY_CLIENT_SECRET=your_client_secret_here

# Your store domain (no https://)
SHOPIFY_STORE=your-store.myshopify.com

# ─────────────────────────────────────────────
# OAuth Redirect URI
# Local:      http://localhost:3000/callback
# ngrok:      https://xxxx.ngrok-free.app/callback
# Production: https://your-domain.com/callback
# ─────────────────────────────────────────────
SHOPIFY_REDIRECT_URI=https://xxxx.ngrok-free.app/callback

# ─────────────────────────────────────────────
# API Settings
# ─────────────────────────────────────────────
SHOPIFY_API_VERSION=2026-07

# ─────────────────────────────────────────────
# Auto-saved after first OAuth install
# ─────────────────────────────────────────────
SHOPIFY_ACCESS_TOKEN=

# ─────────────────────────────────────────────
# Server Settings
# ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development
